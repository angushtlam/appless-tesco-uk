---
import AppLayout from "../layouts/AppLayout.astro";
import UkPhoneNumberGenerator from "../components/UkPhoneNumberGenerator";
---

<AppLayout
  title="Appless T*sco UK"
  description="Help using your Clubcard barcode."
>
  <script is:inline>
    try {
      localStorage.setItem("lastCheckedHelp", Date.now().toString());
    } catch {
      // The help page still works when browser storage is unavailable.
    }
  </script>

  <section class="screen" aria-labelledby="help-title">
    <header class="header">
      <div class="title-row">
        <h1 id="help-title">Appless T*sco UK</h1>
        <a class="card-link" href="/" aria-label="View your Clubcard">
          <span class="card-icon" aria-hidden="true"></span>
        </a>
      </div>
      <img class="logo" src="/logo.jpg" alt="" width="512" height="512" />
    </header>

    <div class="content">
      <article class="card">
        <h2>Stop using random strangers' Clubcards on the internet!</h2>
        <ol>
          <li>Enter your Clubcard number.</li>
          <li>
            Scan the barcode at the till to collect Clubcard points and access
            member-only discounts.
          </li>
        </ol>

        <p>
          Your Clubcard number stays in your browser and is not sent anywhere.
        </p>

        <a class="button" href="/">View Clubcard barcode</a>
      </article>
      <br />
      <article class="card">
        <h2>Getting a Clubcard</h2>
        <ol>
          <li>
            Visit the <a
              href="https://www.tesco.com/account/register/en-GB/"
              target="_blank"
              rel="noopener noreferrer">tesco.com/account/register/en-GB/</a
            > to get started. Use a real email address that you can access.
          </li>
          <li>
            Enter the required information on the page. You can use this number
            generator if you don't have one.

            <UkPhoneNumberGenerator client:only="react" />
          </li>
          <li>
            You can also enter any address. If you don't have a postal address,
            you can use any or mine at "Winfield House, Outer Circle, Regents
            Park, London, NW1 4RT".
          </li>
          <li>
            Once registered, you'll receive an email with your Clubcard number.
            Copy it and paste into the card number field to view its barcode.
          </li>
        </ol>
      </article>
      <br />
      <article class="card">
        <h2>About this tool</h2>
        <p>
          This website provides a simple way to display a Clubcard barcode in a
          mobile browser. It may be useful when the official app is unavailable
          or inconvenient to access.
        </p>
        <p>
          This is an independent project and is not affiliated with, endorsed
          by, or operated by Tesco. Use at your own risk.
        </p>
      </article>
      <br />
      <article class="card">
        <h2>Why did you make this?</h2>
        <p>
          Accessing Tesco member discounts is nearly impossible for non-United
          Kingdom residents. Tesco does not display a scannable Clubcard barcode
          directly on their website. You cannot download the official app unless
          you have your app store location set to United Kingdom. The till does
          not allow you to enter your phone number or Clubcard number to take
          advantage of their discounts.
        </p>
        <p>
          As of June 2026, this page still contains accurate information and
          works as expected, but Tesco may update their policies to change
          registration requirements or update barcode formats. Enjoy while it
          lasts!
        </p>
        <p>
          <a
            href="https://github.com/angushtlam/appless-tesco-uk"
            target="_blank"
            rel="noopener noreferrer"
          >
            Source code
          </a>
        </p>
        <p>
          &copy; 2026 Angus to Far <a
            href="https://angustofar.com"
            target="_blank"
            rel="noopener noreferrer">angustofar.com</a
          >
        </p>
      </article>
    </div>
  </section>

  <style>
    .screen {
      min-height: inherit;
      color: #fff;
      background: #0057a6;
    }

    .header {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .title-row {
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) 44px;
      width: 100%;
      min-height: 88px;
      align-items: center;
      padding: calc(18px + env(safe-area-inset-top))
        calc(8px + env(safe-area-inset-right)) 16px
        calc(8px + env(safe-area-inset-left));
      border-bottom: 1px solid rgb(255 255 255 / 12%);
    }

    .logo {
      display: block;
      width: 96px;
      height: 96px;
      margin: 22px 0;
      border-radius: 20px;
    }

    .header h1 {
      grid-column: 2;
      margin: 0;
      font-size: 1.45rem;
      font-weight: 700;
      text-align: center;
    }

    .card-link {
      display: grid;
      grid-column: 3;
      grid-row: 1;
      width: 44px;
      height: 44px;
      place-items: center;
      color: inherit;
    }

    .card-icon {
      position: relative;
      display: block;
      width: 28px;
      height: 20px;
      border: 2px solid currentColor;
      border-radius: 3px;
    }

    .card-icon::before {
      position: absolute;
      top: 4px;
      right: 3px;
      left: 3px;
      height: 3px;
      background: currentColor;
      content: "";
    }

    .content {
      padding: 18px calc(16px + env(safe-area-inset-right))
        calc(28px + env(safe-area-inset-bottom))
        calc(16px + env(safe-area-inset-left));
    }

    .card {
      padding: clamp(28px, 8vw, 42px) 24px 28px;
      border-radius: 28px;
      color: #2d2d2d;
      background: #fff;
    }

    .card h2 {
      margin: 0 0 24px;
      font-size: 1.55rem;
      line-height: 1.1;
    }

    .card ol {
      display: grid;
      gap: 18px;
      margin: 0;
      padding-left: 24px;
      color: #555;
      line-height: 1.5;
    }

    .card p {
      margin: 28px 0 0;
      color: #666;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .button {
      display: block;
      margin-top: 32px;
      padding: 15px 20px;
      border-radius: 999px;
      color: #fff;
      background: #0057a6;
      font-weight: 700;
      text-align: center;
      text-decoration: none;
    }
  </style>
</AppLayout>
